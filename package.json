{
  "name": "ortunc-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "SERVER_DEPLOY=1 SKIP_MEVZUAT_SYNC=1 node scripts/prebuild.mjs && SERVER_DEPLOY=1 next dev",
    "prebuild": "node scripts/prebuild.mjs",
    "sync:mevzuat": "node scripts/sync-mevzuat-guncellemeleri.mjs --force",
    "sync:mevzuat:list": "node scripts/sync-mevzuat-guncellemeleri.mjs --list-only --force",
    "sync:mevzuat:details": "node scripts/sync-mevzuat-guncellemeleri.mjs --details-only",
    "sync:mevzuat:fast": "node scripts/sync-mevzuat-guncellemeleri.mjs --details-only --fast",
    "sync:mevzuat:parallel": "node scripts/sync-mevzuat-parallel.mjs",
    "build": "next build",
